# Server
SERVER_PORT=8080

# FRONTEND_ORIGIN: comma-separated browser origins allowed for CORS and JWT from the Vite app.
# In production, include every origin that calls this API (e.g. Vercel diagnosis app + your homepage domain).
# Example: FRONTEND_ORIGIN=https://mebody-jjh.vercel.app,https://www.example.com
FRONTEND_ORIGIN=http://127.0.0.1:3000,http://localhost:3000

# MEBODY_APP_URL: public URL of the diagnosis (Vite) app used for homepage CTAs (data-app-url via /api/public/config).
# Defaults to the production diagnosis app when unset.
MEBODY_APP_URL=https://mebody-jjh.vercel.app

# Supabase Postgres direct connection or pooler JDBC URL
SUPABASE_DB_URL=jdbc:postgresql://aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
SUPABASE_DB_USERNAME=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your-database-password

# Choose one JWT strategy.
# Legacy HS256 projects can use SUPABASE_JWT_SECRET.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# RS256/JWKS projects can use SUPABASE_JWKS_URL instead.
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# Server only. Never expose this to Vite/client code.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
